#!/bin/bash
# claude-pod — run Claude Code in a rootless Podman container

# Bail out early if not running under bash (POSIX-compatible check so sh shows a clear error)
if [ -z "${BASH_VERSION:-}" ]; then
    echo "error: claude-pod requires bash. Run with: bash claude-pod <command>" >&2
    exit 1
fi

set -euo pipefail

IMAGE="claude-pod:latest"
CONFIG_FILE="${HOME}/.config/claude-pod/config.toml"
CONTAINER_NAME_PREFIX="claude-pod"
DATA_DIR="${HOME}/.local/share/claude-pod"
# Resolve the real path of this script (follows symlinks) so build works from any directory
# When piped from curl (bash -s), BASH_SOURCE[0] is empty — fall back gracefully
if [[ -n "${BASH_SOURCE[0]:-}" && -f "${BASH_SOURCE[0]}" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
else
    SCRIPT_DIR=""
fi
# For build context, prefer SCRIPT_DIR if it has both build files, else fall back to DATA_DIR
if [[ -n "$SCRIPT_DIR" && -f "${SCRIPT_DIR}/Containerfile" && -f "${SCRIPT_DIR}/entrypoint.sh" ]]; then
    BUILD_DIR="$SCRIPT_DIR"
else
    BUILD_DIR="$DATA_DIR"
fi

# --- Config file parsing (simple TOML subset) ---

cfg_get() {
    # Extract a key from the config file. Handles simple key = "value" pairs.
    local section="$1" key="$2"
    if [[ -f "$CONFIG_FILE" ]]; then
        awk -v section="[$section]" -v key="$key" '
            $0 == section { in_section=1; next }
            /^\[/ { in_section=0 }
            in_section && $1 == key {
                # Strip key = "value" down to value
                sub(/^[^=]*=\s*/, "")
                gsub(/^"|"$/, "")
                print
            }
        ' "$CONFIG_FILE"
    fi
}

cfg_get_array() {
    # Extract a TOML array value as newline-separated items.
    local section="$1" key="$2"
    if [[ -f "$CONFIG_FILE" ]]; then
        awk -v section="[$section]" -v key="$key" '
            $0 == section { in_section=1; next }
            /^\[/ { in_section=0 }
            in_section && $1 == key {
                # Extract the array contents between [ ]
                match($0, /\[(.+)\]/, arr)
                n = split(arr[1], items, ",")
                for (i=1; i<=n; i++) {
                    gsub(/^[ \t"]+|[ \t"]+$/, "", items[i])
                    if (items[i] != "") print items[i]
                }
            }
        ' "$CONFIG_FILE"
    fi
}

# --- Helpers ---

die() { echo "error: $*" >&2; exit 1; }

require_image() {
    if ! podman image exists "$IMAGE" 2>/dev/null; then
        die "Image '$IMAGE' not found. Run 'claude-pod build' first."
    fi
}

suggest_podman_install() {
    echo "error: Podman is not installed." >&2
    local install_cmd=""
    if command -v dnf >/dev/null 2>&1; then
        install_cmd="sudo dnf install -y podman"
    elif command -v apt-get >/dev/null 2>&1; then
        install_cmd="sudo apt-get install -y podman"
    elif command -v brew >/dev/null 2>&1; then
        install_cmd="brew install podman"
    elif command -v pacman >/dev/null 2>&1; then
        install_cmd="sudo pacman -S podman"
    elif command -v zypper >/dev/null 2>&1; then
        install_cmd="sudo zypper install -y podman"
    fi

    if [[ -n "$install_cmd" ]]; then
        echo "Install with: $install_cmd" >&2
        # Offer to install if running interactively
        if [[ -t 0 && -t 1 ]]; then
            read -rp "Install now? [y/N] " answer
            if [[ "$answer" =~ ^[Yy]$ ]]; then
                $install_cmd || die "Podman installation failed."
                return
            fi
        fi
    else
        echo "See https://podman.io/docs/installation for install instructions." >&2
    fi
    exit 1
}

require_podman() {
    command -v podman >/dev/null 2>&1 || suggest_podman_install
}

# Mount each item under $HOME with appropriate permissions.
# CWD's top-level parent is mounted rw; .claude.json is staged at /mnt;
# known writable dirs (.claude, .config, .local) are rw; everything else ro.
# Accepts a space-separated list of writable dirs to also mount rw.
mount_home_items() {
    local -n _args=$1
    local cwd="$2"
    local extra_rw="${3:-}"
    local cwd_top=""
    if [[ "$cwd" == "$HOME"/* ]]; then
        local rel="${cwd#"$HOME"/}"
        cwd_top="${HOME}/${rel%%/*}"
    fi

    for item in "${HOME}"/.[!.]* "${HOME}"/..?* "${HOME}"/*; do
        [[ -e "$item" ]] || continue
        local base
        base=$(basename "$item")
        case "$base" in
            .claude.json)
                _args+=(-v "${item}:/mnt/.claude.json:ro") ;;
            .claude|.config|.local)
                _args+=(-v "${item}:${item}") ;;
            *)
                if [[ "$item" == "$cwd_top" || " $extra_rw " == *" $item "* ]]; then
                    _args+=(-v "${item}:${item}")
                else
                    _args+=(-v "${item}:${item}:ro")
                fi ;;
        esac
    done
}

# Only paths outside $HOME need their own mount.
cwd_needs_mount() {
    local cwd="$1"
    [[ "$cwd" != "$HOME" && "$cwd" != "$HOME"/* ]]
}

# --- Subcommands ---

cmd_build() {
    require_podman
    if [[ ! -f "${BUILD_DIR}/Containerfile" || ! -f "${BUILD_DIR}/entrypoint.sh" ]]; then
        die "Build files (Containerfile, entrypoint.sh) not found in ${BUILD_DIR}. Run 'claude-pod install' first."
    fi
    local shell_name
    shell_name=$(basename "${SHELL:-bash}")
    # Prefer getent if available, but don't fail if it's missing
    if command -v getent >/dev/null 2>&1; then
        shell_name=$(basename "$(getent passwd "$(whoami)" | cut -d: -f7)") || shell_name=$(basename "${SHELL:-bash}")
    fi
    case "$shell_name" in
        bash|zsh|fish) ;;
        *) echo "warning: unsupported shell '$shell_name', defaulting to bash" >&2; shell_name=bash ;;
    esac
    echo "Building $IMAGE for $(whoami) (uid=$(id -u), gid=$(id -g), shell=${shell_name})..."
    podman build -t "$IMAGE" \
        --build-arg "USERNAME=$(whoami)" \
        --build-arg "USER_UID=$(id -u)" \
        --build-arg "USER_GID=$(id -g)" \
        --build-arg "USER_SHELL=${shell_name}" \
        "$BUILD_DIR"
}

cmd_run() {
    require_podman
    require_image

    local detach=false
    local network=""
    local notify_cmd=""
    local writable_dirs=()
    local claude_args=()

    # Default notify command from config
    notify_cmd=$(cfg_get "defaults" "notify_command")
    # Backward-compatible fallback for legacy notify_topic
    if [[ -z "$notify_cmd" ]]; then
        local legacy_topic
        legacy_topic=$(cfg_get "defaults" "notify_topic") || true
        if [[ -n "${legacy_topic:-}" ]]; then
            if [[ ! "$legacy_topic" =~ ^[A-Za-z0-9._-]+$ ]]; then
                die "Invalid notify topic '$legacy_topic' in config. Allowed characters: letters, digits, '.', '_', '-'"
            fi
            notify_cmd="curl -s -d \"Claude Code finished in \$WORKSPACE (exit \$EXIT_CODE)\" https://ntfy.sh/${legacy_topic}"
            echo "warning: 'defaults.notify_topic' is deprecated; use 'defaults.notify_command' instead." >&2
        fi
    fi

    # Parse flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --detach)        detach=true; shift ;;
            --network=*)     network="${1#--network=}"; shift ;;
            --notify)
                # Shorthand for ntfy.sh: --notify <topic>
                [[ $# -lt 2 ]] && die "Flag --notify requires a topic"
                local topic="$2"
                if [[ ! "$topic" =~ ^[A-Za-z0-9._-]+$ ]]; then
                    die "Invalid notify topic '$topic'. Allowed characters: letters, digits, '.', '_', '-'"
                fi
                notify_cmd="curl -s -d \"Claude Code finished in \$WORKSPACE (exit \$EXIT_CODE)\" https://ntfy.sh/${topic}"
                shift 2 ;;
            --notify-cmd)
                [[ $# -lt 2 ]] && die "Flag --notify-cmd requires a command"
                notify_cmd="$2"; shift 2 ;;
            -wd|--writable-dir)
                [[ $# -lt 2 ]] && die "Flag --writable-dir requires a directory"
                writable_dirs+=("$2"); shift 2 ;;
            --)              shift; claude_args=("$@"); break ;;
            -*)              claude_args=("$@"); break ;;
            *)               die "Unknown command: $1. See 'claude-pod --help'." ;;
        esac
    done

    local cwd
    cwd="$(pwd)"

    # Core podman args
    local args=(
        --rm
        --name "${CONTAINER_NAME_PREFIX}-$(date +%s)"
        # Map host UID/GID into container so file ownership is correct
        --userns=keep-id
        # Disable SELinux relabeling — :Z would privately relabel host dirs
        --security-opt label=disable
        -w "${cwd}"
    )

    mount_home_items args "$cwd" "${writable_dirs[*]}"

    # Mount cwd read-write if outside $HOME
    if cwd_needs_mount "$cwd"; then
        args+=(-v "${cwd}:${cwd}")
    fi

    # Mount Homebrew (linuxbrew) if present
    if [[ -n "${HOMEBREW_PREFIX:-}" && -d "$HOMEBREW_PREFIX" ]]; then
        args+=(-v "${HOMEBREW_PREFIX}:${HOMEBREW_PREFIX}:ro")
    fi

    # Pass through API key if set (not required — OAuth creds in ~/.claude work too)
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        args+=(-e ANTHROPIC_API_KEY)
    fi

    # Notification command (passed as env var, entrypoint.sh picks it up)
    if [[ -n "$notify_cmd" ]]; then
        args+=(-e "NOTIFY_CMD=${notify_cmd}")
    fi

    # Network mode
    if [[ -n "$network" ]]; then
        args+=(--network="$network")
    fi

    # Extra env vars from config
    while IFS= read -r var; do
        [[ -n "$var" ]] && args+=(-e "$var")
    done < <(cfg_get_array "defaults" "extra_env")

    # Extra writable dirs (top-level $HOME entries handled by mount_home_items)
    for dir in "${writable_dirs[@]}"; do
        [[ "$dir" == "$HOME" ]] && continue
        args+=(-v "${dir}:${dir}")
    done

    # Extra volumes from config
    while IFS= read -r vol; do
        [[ -n "$vol" ]] && args+=(-v "$vol")
    done < <(cfg_get_array "defaults" "extra_volumes")

    if $detach; then
        args+=(-d)
        podman run "${args[@]}" "$IMAGE" "${claude_args[@]}"
    else
        # Interactive TTY for normal usage
        args+=(-it)
        podman run "${args[@]}" "$IMAGE" "${claude_args[@]}"
    fi
}

cmd_shell() {
    require_podman
    require_image

    local cwd
    cwd="$(pwd)"

    local shell_args=(
        -it --rm
        --userns=keep-id
        --security-opt label=disable
        -w "${cwd}"
    )

    mount_home_items shell_args "$cwd"

    # Mount cwd read-write if outside $HOME
    if cwd_needs_mount "$cwd"; then
        shell_args+=(-v "${cwd}:${cwd}")
    fi

    if [[ -n "${HOMEBREW_PREFIX:-}" && -d "$HOMEBREW_PREFIX" ]]; then
        shell_args+=(-v "${HOMEBREW_PREFIX}:${HOMEBREW_PREFIX}:ro")
    fi

    podman run "${shell_args[@]}" -e CLAUDE_POD_SHELL=1 "$IMAGE"
}

cmd_exec() {
    require_podman
    [[ $# -eq 0 ]] && die "Usage: claude-pod exec <command...>"

    # Find the most recently started claude-pod container
    local container
    container=$(podman ps --filter "name=${CONTAINER_NAME_PREFIX}" --format '{{.Names}}' | head -1)
    [[ -z "$container" ]] && die "No running claude-pod container found."

    podman exec -it "$container" "$@"
}

cmd_ps() {
    require_podman
    podman ps --filter "name=${CONTAINER_NAME_PREFIX}" --format \
        'table {{.Names}}\t{{.Status}}\t{{.Ports}}'
}

cmd_clean() {
    require_podman
    echo "Removing claude-pod image..."
    podman rmi -f "$IMAGE" 2>/dev/null || true
    echo "Done."
}

cmd_install() {
    require_podman

    local ref="main"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ref) [[ $# -lt 2 ]] && die "Flag --ref requires a value"; ref="$2"; shift 2 ;;
            *) die "Unknown install flag: $1" ;;
        esac
    done
    local github_raw="https://raw.githubusercontent.com/xukai92/claude-pod/${ref}"

    mkdir -p "$DATA_DIR"
    mkdir -p "${HOME}/.local/bin"

    # Determine source: local clone or download from GitHub
    if [[ -n "$SCRIPT_DIR" && -f "${SCRIPT_DIR}/Containerfile" && -f "${SCRIPT_DIR}/entrypoint.sh" ]]; then
        echo "Installing from local source (${SCRIPT_DIR})..."
        cp "${SCRIPT_DIR}/entrypoint.sh" "$DATA_DIR/"
        cp "${SCRIPT_DIR}/Containerfile" "$DATA_DIR/"
        cp "${SCRIPT_DIR}/claude-pod" "$DATA_DIR/"
    else
        command -v curl >/dev/null 2>&1 || die "curl is required for remote install."
        echo "Downloading claude-pod from GitHub (ref: ${ref})..."
        curl -fsSL "${github_raw}/claude-pod" -o "$DATA_DIR/claude-pod"
        curl -fsSL "${github_raw}/entrypoint.sh" -o "$DATA_DIR/entrypoint.sh"
        curl -fsSL "${github_raw}/Containerfile" -o "$DATA_DIR/Containerfile"
    fi

    # Remove any existing symlink before copying (cp/install follow symlinks)
    rm -f "${HOME}/.local/bin/claude-pod"
    install -m 755 "$DATA_DIR/claude-pod" "${HOME}/.local/bin/claude-pod"

    echo "Installed claude-pod to ~/.local/bin/claude-pod"

    # Check if ~/.local/bin is in PATH
    if ! echo "${PATH:-}" | tr ':' '\n' | grep -qx "${HOME}/.local/bin"; then
        echo "warning: ~/.local/bin is not in your PATH. Add it to your shell profile." >&2
    fi

    # Build the container image using the staged files (not the clone)
    BUILD_DIR="$DATA_DIR"
    echo ""
    cmd_build
}

# --- Main ---

case "${1:-}" in
    install) shift; cmd_install "$@" ;;
    build) shift; cmd_build "$@" ;;
    run)   shift; cmd_run "$@" ;;
    shell) shift; cmd_shell "$@" ;;
    exec)  shift; cmd_exec "$@" ;;
    ps)    shift; cmd_ps "$@" ;;
    clean) shift; cmd_clean "$@" ;;
    -h|--help)
        cat <<'EOF'
Usage: claude-pod [command] [options]

Running with no command starts an interactive Claude Code session (same as 'run').
Unrecognized flags are forwarded to Claude Code.
claude-pod flags must come before Claude Code flags.

Commands:
  install [--ref <ref>] Install claude-pod to ~/.local/bin and build image
  build                Build the container image
  run [flags] [-- <claude args>]
                       Start an interactive Claude Code session
  shell                Drop into a bash shell in the container
  exec <command>       Run a command in a running container
  ps                   List running claude-pod containers
  clean                Remove volumes and image

Run flags:
  --detach             Run in background (print container ID)
  --network=none       Disable all networking
  --notify <topic>     Send ntfy.sh notification when session ends
  --notify-cmd <cmd>   Run custom command on exit ($WORKSPACE, $EXIT_CODE)
  -wd, --writable-dir <path>
                       Mount a dir read-write (can be repeated)

Config: ~/.config/claude-pod/config.toml
EOF
        exit 1
        ;;
    *)  cmd_run "$@" ;;
esac
